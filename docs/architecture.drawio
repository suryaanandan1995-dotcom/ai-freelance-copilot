<mxfile host="app.diagrams.net" agent="ai-freelance-copilot" version="24.0.0">
  <diagram id="ai-freelance-copilot-arch" name="Architecture">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="AI Freelance Copilot — Architecture (NEVER auto-submits; a human reviews &amp; submits)" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="820" height="30" as="geometry" />
        </mxCell>

        <mxCell id="sources" value="Lead Sources (read-only)&#10;Upwork RSS · remote boards&#10;Contra/startup · HN who-is-hiring" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="220" height="80" as="geometry" />
        </mxCell>

        <mxCell id="dedupe" value="Fetch + Dedupe&#10;(sources.registry.fetch_all)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
