# AI Freelance Copilot — environment configuration
# Copy to `.env` and fill in. ALL variables are prefixed COPILOT_ (pydantic-settings).
# Safe, offline defaults ship in config.py; you only need to set what you change.

# --- Storage ---------------------------------------------------------------
# SQLite by default (offline). For production set a PostgreSQL DSN.
COPILOT_DATABASE_URL=sqlite:///copilot.db

# --- Claude API ------------------------------------------------------------
# Required only for live runs; tests + offline runs need no key.
ANTHROPIC_API_KEY=
COPILOT_ANTHROPIC_API_KEY=
COPILOT_MODEL_OPUS=claude-opus-4-8
COPILOT_MODEL_SONNET=claude-sonnet-4-6

# --- Cost guardrail --------------------------------------------------------
# Hard cap on Claude spend per pipeline run (USD). The run stops cleanly at it.
COPILOT_MAX_USD_PER_RUN=2.0

# --- Pipeline policy -------------------------------------------------------
COPILOT_MIN_FIT_SCORE=70
COPILOT_MAX_LEADS_PER_RUN=50
COPILOT_MAX_PROPOSALS_PER_DAY=15

# --- Safety (do NOT flip without understanding platform ToS) ---------------
# Auto-send is a ToS violation on Upwork/LinkedIn. Humans submit, always.
COPILOT_DRY_RUN=true
COPILOT_ALLOW_SEND=false

# --- Auto-email outreach (the ONLY channel safe to fully automate) ---------
# Sending email from your own address is not a platform ToS violation. Emails
# go ONLY to leads that publicly posted a contact address (B2B legitimate
# interest), are rate-limited, deduped (never email an address twice), and
# carry a plain-text opt-out footer. Upwork/LinkedIn stay human-submit.
# Master gate — nothing sends unless this is true AND the SMTP_* vars are set.
COPILOT_AUTO_EMAIL=false
# Conservative daily cap (reply quality + domain reputation + legality).
COPILOT_MAX_EMAILS_PER_DAY=8
# Only email strong-fit leads (0-100).
COPILOT_OUTREACH_MIN_FIT=80
# Where "unsubscribe" replies go (Reply-To + footer). Empty -> owner_email.
COPILOT_OPT_OUT_MAILBOX=

# --- Auto-reply (autonomous handling of prospect replies) ------------------
# Reads replies to our cold outreach over IMAP and responds autonomously in the
# owner's voice. Fully auto-negotiates EXCEPT it never commits pricing, scope,
# timeline, or contracts — those defer to a cal.com call. Every auto-reply BCCs
# the owner, and each thread is capped so it can't loop. IMAP reuses SMTP_USER +
# SMTP_PASSWORD (a Gmail app password works for both).
# Master gate — nothing is read or sent unless this is true AND SMTP is set.
COPILOT_AUTO_REPLY=false
COPILOT_IMAP_HOST=imap.gmail.com
COPILOT_IMAP_PORT=993
# Safety stop against reply loops: max autonomous replies per prospect thread.
COPILOT_MAX_REPLIES_PER_THREAD=6
# Optional rough rate the bot MAY mention as a ballpark. Blank = always defer
# pricing to the call (the safe default).
COPILOT_STANDARD_RATE=

# --- Dashboard authentication ----------------------------------------------
# HTTP Basic auth guards the dashboard UI + all write actions. SET A PASSWORD
# before exposing the dashboard on any public URL (Render/tunnel/etc).
# Leaving COPILOT_DASHBOARD_PASSWORD BLANK DISABLES auth entirely (fine for
# local dev / SSH-tunnel use). /healthz, /metrics, and /webhooks/cal stay open.
COPILOT_DASHBOARD_USER=admin
COPILOT_DASHBOARD_PASSWORD=

# --- Call tracking (cal.com booking webhook) -------------------------------
# Shared secret for the cal.com BOOKING_CREATED webhook -> /webhooks/cal. The
# endpoint verifies the X-Cal-Signature-256 HMAC of the raw body. Blank skips
# verification (dev only). The dashboard must be publicly reachable to receive it.
COPILOT_CAL_WEBHOOK_SECRET=

# --- Notifications ---------------------------------------------------------
# Channel for the post-run digest: email | whatsapp | none
COPILOT_NOTIFY_CHANNEL=email
# Used to build dashboard links inside the digest.
COPILOT_DASHBOARD_BASE_URL=http://localhost:8000

# Email / SMTP (primary channel). Leave smtp_host empty to disable email.
COPILOT_SMTP_HOST=
COPILOT_SMTP_PORT=587
COPILOT_SMTP_USER=
COPILOT_SMTP_PASSWORD=
COPILOT_SMTP_FROM=
COPILOT_NOTIFY_EMAIL_TO=

# WhatsApp Business Cloud API (optional). All three required to enable.
COPILOT_WHATSAPP_TOKEN=
COPILOT_WHATSAPP_PHONE_ID=
COPILOT_WHATSAPP_TO=

# --- RAG knowledge base ----------------------------------------------------
COPILOT_PORTFOLIO_REPOS_PATH=..
COPILOT_RAG_STORE_PATH=data/portfolio_kb.json

# --- Identity (used in proposals / signature) ------------------------------
COPILOT_OWNER_NAME=Surya A
COPILOT_OWNER_EMAIL=suryaanandan1995@gmail.com
COPILOT_OWNER_LINKEDIN=https://www.linkedin.com/in/surya-devsecops/
COPILOT_OWNER_SITE=https://suryaanandan1995-dotcom.github.io
COPILOT_OWNER_CALENDLY=https://cal.com/surya-devsecops/15min
