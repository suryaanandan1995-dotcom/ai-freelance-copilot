[Unit]
Description=AI Freelance Copilot — mission-control dashboard
After=network.target

[Service]
WorkingDirectory=/home/surya/github-portfolio/ai-freelance-copilot
EnvironmentFile=/home/surya/github-portfolio/ai-freelance-copilot/.env
ExecStart=/home/surya/github-portfolio/ai-freelance-copilot/.venv/bin/python main.py dashboard --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
